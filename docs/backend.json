
{
  "entities": {
    "EurovisionEntry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "EurovisionEntry",
      "type": "object",
      "description": "Represents a single Eurovision song entry for a specific year and stage.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the EurovisionEntry entity."
        },
        "year": {
          "type": "number",
          "description": "The year the Eurovision song entry participated."
        },
        "country": {
          "type": "string",
          "description": "The country represented by this Eurovision entry."
        },
        "flagUrl": {
          "type": "string",
          "description": "The URL for the country's flag image.",
          "format": "uri"
        },
        "artist": {
          "type": "string",
          "description": "The artist(s) performing the song."
        },
        "songTitle": {
          "type": "string",
          "description": "The title of the Eurovision song."
        },
        "videoUrl": {
          "type": "string",
          "description": "The URL for the embedded performance video.",
          "format": "uri"
        },
        "spotifyUrl": {
          "type": "string",
          "description": "The URL for the song on Spotify.",
          "format": "uri"
        },
        "thumbnailUrl": {
          "type": "string",
          "description": "An optional URL for a custom artist or performance photo.",
          "format": "uri"
        },
        "stage": {
          "type": "string",
          "enum": ["Final", "Semi-Final 1", "Semi-Final 2", "Prequalification", "Eurodromio", "Be.So.", "Mu.Si.Ka."],
          "description": "The stage of the contest the entry participated in."
        },
        "description": {
          "type": "string",
          "description": "An optional description or background information about the entry."
        },
        "bioUrl": {
          "type": "string",
          "description": "Link to the artist's bio on infegreece.com",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "year",
        "country",
        "artist",
        "songTitle",
        "videoUrl",
        "stage"
      ]
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "username": {
          "type": "string",
          "description": "A user-friendly username."
        }
      },
      "required": [
        "id",
        "username"
      ]
    },
    "Vote": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Vote",
      "type": "object",
      "description": "Records a user's vote for a specific Eurovision entry.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Vote entity."
        },
        "userId": {
          "type": "string",
          "description": "Reference to the User who cast this vote."
        },
        "eurovisionEntryId": {
          "type": "string",
          "description": "Reference to the EurovisionEntry."
        },
        "year": {
          "type": "number",
          "description": "The year for which the vote was cast."
        },
        "points": {
          "type": "number",
          "description": "The points awarded (1-12)."
        },
        "votedAt": {
          "type": "string",
          "description": "Timestamp.",
          "format": "date-time"
        },
        "feedback": {
          "type": "string",
          "description": "Optional user feedback for the vote."
        }
      },
      "required": [
        "id",
        "userId",
        "eurovisionEntryId",
        "year",
        "points",
        "votedAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google"
    ]
  },
