
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a user-ownership model for votes and profiles.
     * Administrative actions are restricted to authorized accounts.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * Checks if the user is an administrator. 
     * An admin is a user whose UID exists in the 'roles_admin' collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Public registry of Eurovision songs. 
     */
    match /eurovision_entries/{entryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Collection Group Rule for Scoreboard.
     * Essential for aggregating results by year across all users.
     */
    match /{path=**}/votes/{voteId} {
      allow read: if true;
    }

    /**
     * @description User profile documents.
     */
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      /**
       * Sub-collection of votes. 
       */
      match /votes/{voteId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    /**
     * @description Global admin roles list.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if false; 
    }
  }
}
