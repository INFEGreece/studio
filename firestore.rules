rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a strict User-Ownership model for personal profiles and voting records,
     * combined with a Database Access Control (DBAC) model for administrative management of 
     * the Eurovision song registry. 
     *
     * DATA STRUCTURE
     * - /eurovision_entries/{entryId}: Publicly readable song database managed by admins.
     * - /users/{userId}: Private user profiles accessible only by the owner.
     * - /users/{userId}/votes/{voteIdentifier}: Private user subcollections for voting data.
     * - /roles_admin/{adminId}: A restricted collection used to verify administrative privileges.
     *
     * KEY SECURITY DECISIONS
     * - Identity Verification: All write operations require a verified `request.auth.uid`.
     * - DBAC for Admins: Instead of checking custom claims, rules perform a lookup against 
     *   the `/roles_admin` collection to authorize metadata management.
     * - Relational Integrity: In this prototyping phase, we strictly enforce that the `userId` 
     *   inside documents matches the URL path and the authenticated user's ID, but we do not 
     *   enforce the full schema of content fields (e.g., song titles, artist names).
     * - Denormalization: The `Vote` entity includes a `userId` field to allow for fast, 
     *   authorization-independent checks without needing to look up the parent user document.
     */

    // --- Global Helper Functions ---

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the user's UID matches the owner of an existing document. */
    function isExistingOwner(ownerId) {
      return resource != null && isOwner(ownerId);
    }

    /** 
     * Checks if the user is an administrator by looking up their ID 
     * in the global admin roles collection. 
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Public registry of Eurovision songs. Readable by anyone, manageable only by admins.
     * @path /eurovision_entries/{entryId}
     * @allow (get) Any anonymous visitor viewing the song list.
     * @deny (create) A standard user attempting to add a new song entry.
     * @principle Public read with role-based write access (DBAC).
     */
    match /eurovision_entries/{entryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description User profile documents. Restricted to the specific user for both read and write.
     * @path /users/{userId}
     * @allow (create) Authenticated user 'uid_123' creating their own profile at /users/uid_123.
     * @deny (get) User 'uid_456' attempting to read 'uid_123's profile.
     * @principle Enforces path-based ownership and relational integrity for the primary user ID.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Individual votes cast by users. Nested under the user to allow secure listing.
     * @path /users/{userId}/votes/{voteIdentifier}
     * @allow (create) User 'uid_123' casting a vote where data.userId is 'uid_123'.
     * @deny (list) User 'uid_456' attempting to query the votes subcollection of 'uid_123'.
     * @principle Private subcollection access restricted to the parent owner with internal field validation.
     */
    match /users/{userId}/votes/{voteIdentifier} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Global admin roles. This collection is for internal authorization checks.
     * @path /roles_admin/{adminId}
     * @allow (get) An admin checking their own status or listing other admins.
     * @deny (update) Any user attempting to grant themselves administrative privileges.
     * @principle Secure role storage; writes are forbidden via client-side rules to ensure manual/server-side control.
     */
    match /roles_admin/{adminId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}