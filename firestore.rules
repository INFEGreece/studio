rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a strict User-Ownership model for personal profiles and voting records.
     * Administrative actions on the global song database are restricted to authorized accounts.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * Checks if the user is an administrator. 
     * An admin is a user whose UID exists in the 'roles_admin' collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Public registry of Eurovision songs. 
     * READ: Publicly accessible.
     * WRITE: Only authorized administrators.
     */
    match /eurovision_entries/{entryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description User profile documents. Restricted to the specific user.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId);
    }

    /**
     * @description Individual votes cast by users. 
     * Nested under the user to ensure private, isolated voting data.
     */
    match /users/{userId}/votes/{voteIdentifier} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(userId);
    }

    /**
     * @description Global admin roles list.
     * Only admins can see who else is an admin. No one can write here via client.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if false; 
    }
  }
}