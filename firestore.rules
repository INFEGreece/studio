
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * Public read for entries and aggregated votes (scoreboard).
     * Protected write for user-specific data and admin roles.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Public registry of Eurovision songs. 
     */
    match /eurovision_entries/{entryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description User profile documents.
     */
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
      
      /**
       * @description Individual votes inside a user document.
       */
      match /votes/{voteId} {
        allow read: if true;
        allow create, update: if isSignedIn() && request.auth.uid == userId && request.resource.data.userId == userId;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }

    /**
     * @description Global admin roles list.
     */
    match /roles_admin/{adminId} {
      allow get: if true;
      allow list: if isAdmin();
      allow write: if false; 
    }

    /**
     * @description Collection Group Rule for ALL 'votes' collections.
     * This allows the global scoreboard query to aggregate votes across all users.
     */
    match /{path=**}/votes/{voteId} {
      allow read, list: if true;
    }
  }
}
