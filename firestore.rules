
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * Public read for entries and aggregated votes (scoreboard).
     * Protected write for user-specific data and admin roles.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * Checks if the user is an administrator. 
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Public registry of Eurovision songs. 
     */
    match /eurovision_entries/{entryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Collection Group Rule for Votes.
     * This is CRITICAL for the Scoreboard to function across all users.
     */
    match /{path=**}/votes/{voteId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == request.resource.data.userId;
    }

    /**
     * @description User profile documents.
     */
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      /**
       * Sub-collection of votes (Direct access).
       */
      match /votes/{voteId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    /**
     * @description Global admin roles list.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if false; 
    }
  }
}
