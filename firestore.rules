rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a strict User-Ownership model for personal profiles and voting records.
     * For the eurovision_entries collection, we are temporarily allowing public writes to facilitate 
     * prototyping and testing of the administrative features without requiring complex role setup.
     *
     * DATA STRUCTURE
     * - /eurovision_entries/{entryId}: Publicly readable and writable song database (for prototyping).
     * - /users/{userId}: Private user profiles accessible only by the owner.
     * - /users/{userId}/votes/{voteIdentifier}: Private user subcollections for voting data.
     * - /roles_admin/{adminId}: A restricted collection used to verify administrative privileges.
     */

    // --- Global Helper Functions ---

    /** Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the user's UID matches the owner of an existing document. */
    function isExistingOwner(ownerId) {
      return resource != null && isOwner(ownerId);
    }

    /** 
     * Checks if the user is an administrator. 
     * Note: Temporarily bypassed for eurovision_entries write access.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Public registry of Eurovision songs. 
     * @allow (all) Public access for prototyping purposes.
     */
    match /eurovision_entries/{entryId} {
      allow read, write: if true;
    }

    /**
     * @description User profile documents. Restricted to the specific user for both read and write.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Individual votes cast by users. Nested under the user to allow secure listing.
     */
    match /users/{userId}/votes/{voteIdentifier} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Global admin roles.
     */
    match /roles_admin/{adminId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}